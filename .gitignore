node_modules
test-tmp
data
dist

# Scan audit results (large JSON files, not tracked) — delivered via HuggingFace
scan-a11y-audit/results/*.json
scan-a11y-audit/results/*.csv
scan-a11y-audit/node_modules
# HTML snapshots (21M of raw site captures, audit evidence only — verify-all does
# NOT read these). Delivered via the HuggingFace tarball and placed by
# setup-workspace.sh, mirroring data/ and scan-a11y-audit/results/. metadata.json
# (provenance index) travels with the snapshots.
scan-a11y-audit/html-snapshots/

# Python
__pycache__/
.pytest_cache/
*.py[cod]
*.egg-info/
.venv/
dist/
build/

# Local data archives (large experiment artifacts, synced via S3 or kept as user-verified backup)
/data.tar
/data.tar.gz
/data.tgz
/data.zip
scan-a11y-audit/results.tar
scan-a11y-audit/results.tar.gz

# Terraform local state/logs
terraform-apply.log
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Editor / IDE (local config, not shared)
.vscode/

# Terraform account-rotation backups (previous burner's state, kept locally for forensic value)
infra/.terraform.*.bak/
infra/terraform.tfstate.*.bak

# AMT audit outputs (regenerable from source; can include absolute paths in file:// URLs)
results/amt/

# verify-all output (regenerated every run; timestamp churn)
results/key-numbers.json

# paper-supplementary/: bundle is derived. Track only the curated docs:
#   README.md (manually curated)
#   reproducibility-statement.md (manually curated)
# All CSV / json / .md statistical reports are derived — regenerate with
# scripts/maintenance/build-supplementary.sh
paper-supplementary/*.csv
paper-supplementary/*.json
paper-supplementary/*.txt
paper-supplementary/statistics-*.md
paper-supplementary/exclusion-narrative.md
paper-supplementary/signature-alignment-report.md

# macOS Finder metadata
.DS_Store

# HuggingFace dataset download staging dir (setup-workspace.sh)
.hf-stage
