# Normalize line endings for all text files.
# Prevents CRLF pollution when editing on Windows and syncing to macOS/Linux.
* text=auto eol=lf

# Explicit binary types (never normalize)
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.zip     binary
*.tar     binary
*.tar.gz  binary
*.tgz     binary
*.gz      binary
*.har     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.xlsx    binary

# Scripts that must stay LF even on Windows checkouts
*.sh      text eol=lf
*.py      text eol=lf
*.ts      text eol=lf
*.js      text eol=lf
*.json    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.md      text eol=lf
