# Copy to terraform.tfvars and fill in your values
aws_region    = "us-east-1"
instance_type = "r6i.2xlarge"
project_name  = "a11y-platform"
github_repo   = "https://github.com/Alex-jjh/ai-agent-accessibility.git"

# No SSH key needed — access via SSM Session Manager:
#   aws ssm start-session --target <instance-id>
