{
  "commands": [
    "sudo -u ec2-user bash -lc 'cd ~/platform/data/smoker-shard-a && python3.11 -c \"",
    "import json, glob, collections",
    "outcomes = collections.Counter()",
    "steps_by_outcome = collections.defaultdict(list)",
    "tasks_by_outcome = collections.defaultdict(set)",
    "no_axtree_count = 0",
    "login_fail_count = 0",
    "total = 0",
    "for p in glob.glob(\\\"*/cases/*.json\\\"):",
    "    try:",
    "        d = json.load(open(p))",
    "        t = d[\\\"trace\\\"]",
    "        total += 1",
    "        outcomes[t[\\\"outcome\\\"]] += 1",
    "        steps_by_outcome[t[\\\"outcome\\\"]].append(t[\\\"totalSteps\\\"])",
    "        tasks_by_outcome[t[\\\"outcome\\\"]].add(d[\\\"taskId\\\"])",
    "        if t[\\\"steps\\\"] and \\\"No accessibility tree available\\\" in t[\\\"steps\\\"][0][\\\"observation\\\"]:",
    "            no_axtree_count += 1",
    "        if \\\"ui_login for shopping_admin failed\\\" in (t.get(\\\"bridgeLog\\\") or \\\"\\\"):",
    "            login_fail_count += 1",
    "    except Exception as e:",
    "        pass",
    "print(f\\\"Total: {total}\\\")",
    "for o, c in outcomes.most_common():",
    "    s = steps_by_outcome[o]",
    "    print(f\\\"  {o}: {c} ({100*c/total:.1f}%) median_steps={sorted(s)[len(s)//2] if s else 0}\\\")",
    "print(f\\\"With empty first observation: {no_axtree_count}/{total}\\\")",
    "print(f\\\"With ui_login admin failed: {login_fail_count}/{total}\\\")",
    "print(f\\\"Unique tasks: {len(set().union(*tasks_by_outcome.values()))}\\\")",
    "\"'"
  ],
  "executionTimeout": ["60"]
}
